# Experiment runner
# =============================================================================
def run_experiment(exp_name, dim_list, n_chains=4, eval_budget=20000):
    logprint("\n" + "=" * 92)
    logprint(f"Experiment: {exp_name}")
    logprint("=" * 92)

    results = []

    outer_iter = dim_list
    if TQDM_AVAILABLE:
        outer_iter = tqdm(dim_list, desc=f"[{exp_name}] dims", leave=False)

    for dim in outer_iter:

        if exp_name == "BaselineScan":
            prob = build_problem(dim, sigma=0.5, cond_level=20.0, snr_level=1.0)
        elif exp_name == "WellConditioned":
            prob = build_problem(dim, sigma=0.5, cond_level=2.0, snr_level=1.0)
        elif exp_name == "IllConditioned":
            prob = build_problem(dim, sigma=0.5, cond_level=200.0, snr_level=1.0)
        elif exp_name == "LowSNR":
            prob = build_problem(dim, sigma=0.5, cond_level=20.0, snr_level=0.35)
        elif exp_name == "HighSNR":
            prob = build_problem(dim, sigma=0.5, cond_level=20.0, snr_level=2.5)
        else:
            prob = build_problem(dim, sigma=0.5, cond_level=20.0, snr_level=1.0)

        sqrtL = prob["sqrtL"]
        invL = prob["invL"]
        AtA = prob["AtA"]
        Aty = prob["Aty"]
        sigma = prob["sigma"]
        x_true = prob["x_true"].cpu().numpy()
        Sigma_true = prob["Sigma_true"]
        x0 = prob["x0"]
        geom = prob["geom"]

        init_beta = 0.2 / math.sqrt(dim)

        logprint(f"\n--- dim={dim} | sigma={sigma:.4f} | cond={geom['cond']:.1f} | snr_db={geom['snr_db']:.2f} ---")

        for method in METHODS:

            N = eval_budget - 1

            burn_frac = 0.30
            burn = int(N * burn_frac)
            adapt_stop = burn

            logprint(f"\n  [{method}] eval_budget={eval_budget}, N={N}, burn={burn}, adapt_stop={adapt_stop}")

            chains = []
            times = []
            ars = []
            eval_counts = []

            chain_iter = range(n_chains)
            if TQDM_AVAILABLE:
                chain_iter = tqdm(chain_iter, desc=f"{method} chains (d={dim})", leave=False)

            for c in chain_iter:
                x_init = x0 + 0.05 * sqrtL * torch.randn(dim, device=DEVICE, dtype=DTYPE)

                EVAL.reset()

                if method == "Vanilla pCN":
                    s, ar, t = pcn_vanilla(x_init, invL, sqrtL, AtA, Aty, sigma, init_beta, N)

                elif method == "Adap-ESS pCN":
                    s, ar, t = pcn_adap_ess(x_init, invL, sqrtL, AtA, Aty, sigma, init_beta, N, dim, adapt_stop)

                else:
                    s, ar, t = pcn_dual(
                        x_init, invL, sqrtL, AtA, Aty, sigma,
                        init_beta, N, int(0.5 * adapt_stop), dim, adapt_stop
                    )

                chains.append(s)
                times.append(t)
                ars.append(ar)
                eval_counts.append(EVAL.count)

                logprint(f"    chain {c} | AR={ar:.3f} | time={t:.2f}s | eval={EVAL.count}")

            summary = summarize_multichain(chains, burn, x_true, Sigma_true)

            ess_val = summary["ess_concat"]
            ess_minchain = summary["ess_minchain"]

            ess_s = ess_val / max(np.mean(times), 1e-12)
            ess_eval = ess_val / max(np.mean(eval_counts), 1e-12)

            entry = {
                "exp": exp_name,
                "dim": dim,
                "method": method,
                "AR": float(np.mean(ars)),
                "ESS_concat": float(ess_val),
                "ESS_minchain": float(ess_minchain),
                "ESS_s": float(ess_s),
                "ESS_eval": float(ess_eval),
                "Rhat": float(summary["rhat_max"]),
                "Err_mu": float(summary["err_mu"]),
                "Err_cov": float(summary["err_cov"]),
                "Contract": float(summary["contract"]),
                "Time": float(np.mean(times)),
                "burn": int(burn),
                "eval_mean": float(np.mean(eval_counts)),
                "ci": summary["ci"],
                "chains": chains,
                "singular_vals": prob["singular_vals"],
                "prior_std": prob["sqrtL"].detach().cpu().numpy(),
            }

            results.append(entry)

    return results


