    ax_hx.axis("off")
    ax_hy.axis("off")

    ax_main.set_xlabel("Parameter $x_1$")
    ax_main.set_ylabel("Parameter $x_2$")

    beautify_ax(ax_main)
    ax_main.set_title(f"Posterior Concentration: {entry['method']}", fontweight="bold", pad=8)

