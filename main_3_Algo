# =============================================================================
# Posterior evaluation counter
# =============================================================================
class EvalCounter:
    def __init__(self):
        self.count = 0

    def reset(self):
        self.count = 0

    def inc(self, k=1):
        self.count += int(k)


EVAL = EvalCounter()


# =============================================================================
# Log posterior
# =============================================================================
def log_likelihood(x, AtA, Aty, sigma):
    quad_like = torch.dot(x, AtA @ x) - 2.0 * torch.dot(x, Aty)
    return -0.5 * quad_like / (sigma ** 2)


def log_prior(x, invL):
    quad_prior = torch.dot(x * invL, x)
    return -0.5 * quad_prior


def log_posterior(x, invL, AtA, Aty, sigma):
    return log_likelihood(x, AtA, Aty, sigma) + log_prior(x, invL)


# =============================================================================
# ESS utilities
# =============================================================================
def ess_1d(series):
    series = np.asarray(series, dtype=np.float64)
    n = len(series)

    if n < 30:
        return float(max(1, n))

    if np.allclose(series, series[0], atol=1e-12):
        return 1.0

    series = series - series.mean()
    ac = np.correlate(series, series, mode="full")[n - 1:]
    ac = ac / (ac[0] + 1e-30)

    cutoff = min(n, 4000)
    for k in range(1, cutoff):
        if ac[k] < 0:
            cutoff = k
            break

    tau = 1.0 + 2.0 * np.sum(ac[1:cutoff])
    ess = n / max(tau, 1e-12)

    return float(max(1.0, min(n, ess)))


def ess_mean(samples):
    samples = np.asarray(samples, dtype=np.float64)
    d = samples.shape[1]
    return float(np.mean([ess_1d(samples[:, i]) for i in range(d)]))


def ess_min(samples):
    samples = np.asarray(samples, dtype=np.float64)
    d = samples.shape[1]
    return float(np.min([ess_1d(samples[:, i]) for i in range(d)]))


# =============================================================================
# Split-Rhat
# =============================================================================
def split_rhat(chains):
    chains = np.asarray(chains, dtype=np.float64)
    m, n, d = chains.shape

    if n < 50:
        return np.ones(d)

    n2 = n // 2
    split = np.concatenate([chains[:, :n2, :], chains[:, n2:2*n2, :]], axis=0)

    chain_means = split.mean(axis=1)
    chain_vars = split.var(axis=1, ddof=1)

    W = chain_vars.mean(axis=0)
    B = n2 * chain_means.var(axis=0, ddof=1)

    var_hat = ((n2 - 1) / n2) * W + (1 / n2) * B
    Rhat = np.sqrt(var_hat / np.maximum(W, 1e-14))
    return Rhat


# =============================================================================
# Smooth switching
# =============================================================================
def smooth_w(t, t0, s=0.2):
    return 1.0 / (1.0 + math.exp(-(t - t0) / (s * t0 + 1e-12)))


# =============================================================================
# Autocorrelation
# =============================================================================
def autocorr(x, max_lag=200):
    x = np.asarray(x, dtype=np.float64)
    x = x - x.mean()
    n = len(x)

    if n < 5:
        return np.zeros(max_lag)

    ac = np.correlate(x, x, mode="full")[n-1:]
    ac = ac / (ac[0] + 1e-30)
    return ac[:max_lag]


# =============================================================================
# pCN Vanilla
# =============================================================================
def pcn_vanilla(x0, invL, sqrtL, AtA, Aty, sigma, beta, N):
    dim = x0.numel()
    x = x0.clone().flatten()
    samples = np.empty((N, dim), dtype=np.float64)

    acc = 0
    t0 = time.time()

    lp_x = float(log_posterior(x, invL, AtA, Aty, sigma))
    EVAL.inc(1)

    a = math.sqrt(max(1.0 - beta**2, 1e-12))

    for i in range(N):
        xi = torch.randn_like(x)
        y = a * x + beta * sqrtL * xi

        lp_y = float(log_posterior(y, invL, AtA, Aty, sigma))
        EVAL.inc(1)

        log_acc = min(0.0, lp_y - lp_x)
        if torch.rand(()) < math.exp(log_acc):
            x = y
            lp_x = lp_y
            acc += 1

        samples[i] = x.detach().cpu().numpy()

    return samples, acc / N, time.time() - t0


# =============================================================================
# Adaptive pCN (Robbins-Monro acceptance targeting)
# =============================================================================
def pcn_adap_ess(x0, invL, sqrtL, AtA, Aty, sigma, beta0, N, dim, adapt_stop):
    x = x0.clone().flatten()
    samples = np.empty((N, dim), dtype=np.float64)

    logb = math.log(beta0)
    scale = 1.0 / math.sqrt(dim)

    logb_min = math.log(0.004 * scale)
    logb_max = math.log(0.90 * scale)

    acc = 0
    t0 = time.time()

    lp_x = float(log_posterior(x, invL, AtA, Aty, sigma))
    EVAL.inc(1)

    for i in range(N):
        b = math.exp(logb)
        a = math.sqrt(max(1.0 - b**2, 1e-12))

        xi = torch.randn_like(x)
        y = a * x + b * sqrtL * xi

        lp_y = float(log_posterior(y, invL, AtA, Aty, sigma))
        EVAL.inc(1)

        log_acc = min(0.0, lp_y - lp_x)
        if torch.rand(()) < math.exp(log_acc):
            x = y
            lp_x = lp_y
            acc += 1

        samples[i] = x.detach().cpu().numpy()

        # FIXED: ar must be acc/(i+1)
        if i < adapt_stop and i > 0 and i % 200 == 0:
            ar = acc / (i + 1)
            gamma = 0.12 / math.sqrt(i / 200.0 + 1.0)
            logb += gamma * (ar - 0.234)
            logb = float(np.clip(logb, logb_min, logb_max))

    return samples, acc / N, time.time() - t0


# =============================================================================
# Dual-signal pCN
# =============================================================================
def pcn_dual(x0, invL, sqrtL, AtA, Aty, sigma, beta0, N, t_switch, dim, adapt_stop):
    x = x0.clone().flatten()
    samples = np.empty((N, dim), dtype=np.float64)

    logb = math.log(beta0)
    scale = 1.0 / math.sqrt(dim)

    logb_min = math.log(0.004 * scale)
    logb_max = math.log(0.90 * scale)

    acc = 0
    t0 = time.time()

    lp_x = float(log_posterior(x, invL, AtA, Aty, sigma))
    EVAL.inc(1)

    for i in range(N):
        b = math.exp(logb)
        a = math.sqrt(max(1.0 - b**2, 1e-12))

        xi = torch.randn_like(x)
        y = a * x + b * sqrtL * xi

        lp_y = float(log_posterior(y, invL, AtA, Aty, sigma))
        EVAL.inc(1)

        log_acc = min(0.0, lp_y - lp_x)
        if torch.rand(()) < math.exp(log_acc):
            x = y
            lp_x = lp_y
            acc += 1

        samples[i] = x.detach().cpu().numpy()

        if i < adapt_stop and i > 0 and i % 200 == 0:
            ar = acc / (i + 1)
            w = smooth_w(i, t_switch)

            g_acc = ar - 0.234
            g_ess = 0.0

            # ESS feedback only after enough samples
            if i > 2500:
                blk = samples[i-2000:i]
                g_ess = np.clip((ess_mean(blk) / 2000.0) - 0.5, -1.0, 1.0)

            gamma = 0.10 / math.sqrt(i / 200.0 + 1.0)
            logb += gamma * ((1.0 - w) * g_acc + w * g_ess)
            logb = float(np.clip(logb, logb_min, logb_max))

    return samples, acc / N, time.time() - t0


# =============================================================================
# Build experiment instance
# =============================================================================
def build_problem(dim, sigma=0.5, cond_level=20.0, snr_level=1.0):
    sqrtL = torch.linspace(0.5, 4.0, dim, device=DEVICE, dtype=DTYPE)
    invL = 1.0 / (sqrtL ** 2)

    U, _ = torch.linalg.qr(torch.randn(dim, dim, device=DEVICE, dtype=DTYPE))
    V, _ = torch.linalg.qr(torch.randn(dim, dim, device=DEVICE, dtype=DTYPE))

    s = torch.linspace(1.0, 1.0 / cond_level, dim, device=DEVICE, dtype=DTYPE)
    A = U @ torch.diag(s) @ V.T

    x_true = torch.randn(dim, device=DEVICE, dtype=DTYPE) * 0.5

    noise_sigma = sigma / snr_level
    noise = noise_sigma * torch.randn(dim, device=DEVICE, dtype=DTYPE)

    y = A @ x_true + noise

    AtA = A.T @ A
    Aty = A.T @ y

    Precision = AtA / (noise_sigma ** 2) + torch.diag(invL)
    b = Aty / (noise_sigma ** 2)

    x_map = torch.linalg.solve(Precision, b)
    Sigma_true = torch.inverse(Precision).cpu().numpy()

    sig_norm = float(torch.norm(A @ x_true).detach().cpu().item())
    noise_norm = float(torch.norm(noise).detach().cpu().item()) + 1e-30
    snr_ratio = sig_norm / noise_norm
    snr_db = 20.0 * math.log10(max(snr_ratio, 1e-30))

    geom = {
        "cr": float(np.clip(1.0 / cond_level, 0.0, 1.0)),
        "cond": float(cond_level),
        "snr_db": float(snr_db),
    }

    return {
        "sqrtL": sqrtL,
        "invL": invL,
        "A": A,
        "singular_vals": s.detach().cpu().numpy(),
        "AtA": AtA,
        "Aty": Aty,
        "sigma": noise_sigma,
        "x_true": x_true,
        "x0": x_map,
        "Sigma_true": Sigma_true,
        "geom": geom,
    }


# =============================================================================
# Summaries
# =============================================================================
def summarize_multichain(chains, burn, x_true_np, Sigma_true):
    post_chains = [c[burn:] for c in chains]
    post_all = np.concatenate(post_chains, axis=0)

    mu_est = post_all.mean(axis=0)
    cov_est = np.cov(post_all, rowvar=False)

    err_mu = np.linalg.norm(mu_est - x_true_np) / (np.linalg.norm(x_true_np) + 1e-12)
    err_cov = np.linalg.norm(cov_est - Sigma_true, ord="fro") / (np.linalg.norm(Sigma_true, ord="fro") + 1e-12)

    ess_concat = ess_mean(post_all)

    ess_chain = [ess_mean(c) for c in post_chains]
    ess_minchain = float(np.min(ess_chain))

    rhat = split_rhat(np.stack(post_chains, axis=0))
    rhat_max = float(np.max(rhat))

    contract = float(np.trace(cov_est) / (np.trace(Sigma_true) + 1e-12))

    ci = []
    for j in range(min(2, post_all.shape[1])):
        q = np.quantile(post_all[:, j], [0.025, 0.5, 0.975])
        ci.append((float(q[0]), float(q[1]), float(q[2])))

    return {
        "mu_est": mu_est,
        "cov_est": cov_est,
        "err_mu": float(err_mu),
        "err_cov": float(err_cov),
        "ess_concat": float(ess_concat),
        "ess_minchain": float(ess_minchain),
        "rhat_max": float(rhat_max),
        "contract": float(contract),
        "ci": ci,
    }


